{
  "name": "@holler/cli",
  "version": "0.1.0",
  "description": "CLI for setting up Holler against a user's Supabase project",
  "license": "MIT",
  "type": "module",
  "bin": {
    "holler-init": "./dist/index.js",
    "@holler/init": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "prompts": "^2.4.2",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0"
  }
}
