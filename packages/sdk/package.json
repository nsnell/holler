{
  "name": "@holler-vibe/sdk",
  "version": "0.1.0",
  "description": "Drop-in, Figma-style commenting for any web app. Bring your own Supabase.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/holler.umd.js",
  "module": "./dist/holler.esm.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/holler.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/holler.esm.js",
      "require": "./dist/holler.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --mode esm && vite build --mode umd && tsc -p tsconfig.build.json",
    "build:esm": "vite build --mode esm",
    "build:umd": "vite build --mode umd",
    "dev": "vite build --mode umd --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": false
    }
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
